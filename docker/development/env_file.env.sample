# Arches project settings
ARCHES_PROJECT=ogee-demo
INSTALL_DEFAULT_GRAPHS=False
INSTALL_DEFAULT_CONCEPTS=False

# Database connection (point at your shared Postgres instance)
PGUSERNAME=postgres
PGPASSWORD=
PGDBNAME=ogee_demo
PGHOST=
PGPORT=5432

# Elasticsearch connection (point at your shared ES instance)
ARCHES_ESHOST=
ARCHES_ESPORT=9200
ARCHES_ESPASSWORD=
ELASTICSEARCH_PREFIX=ogee_demo

# Celery broker (RabbitMQ)
ARCHES_CELERY_BROKER_URL=amqp://arches:arches@rabbitmq:5672/

# Django settings
DJANGO_MODE=DEV
DJANGO_DEBUG=True
ARCHES_DJANGO_DEBUG=True
DOMAIN_NAMES=*
DJANGO_PORT=80
PYTHONUNBUFFERED=0
TZ=PST
ARCHES_PUBLIC_SERVER_ADDRESS=http://localhost/
